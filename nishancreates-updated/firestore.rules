rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only Nishan can write anything
    // Public can read projects and config
    // Leads are write-only for public (form submissions), read-only for admin

    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "JQAmgoWaiYQ6Jz2RPKNy0B9iP7G3";
    }

    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "JQAmgoWaiYQ6Jz2RPKNy0B9iP7G3";
    }

    match /skills/{skillId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "JQAmgoWaiYQ6Jz2RPKNy0B9iP7G3";
    }

    match /leads/{leadId} {
      // Anyone can submit a lead (create), only admin can read/update/delete
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.uid == "JQAmgoWaiYQ6Jz2RPKNy0B9iP7G3";
    }
  }
}
